# ──────────────────────────────────────────────
# Variables d'environnement pour les scripts AIDEAL
# Copier ce fichier en .env et renseigner les valeurs :
#   cp .env.example .env
# ──────────────────────────────────────────────

# --- Déploiement (deploy_lora_to_prod.sh) ---

# Hôte de production (obligatoire) — ex: root@1.2.3.4
AIDEAL_PROD_HOST=

# Chemin du docker-compose sur le serveur (optionnel, défaut ci-dessous)
# AIDEAL_PROD_COMPOSE=/opt/makesense-ai/docker-compose.yml

# Répertoire distant pour les adaptateurs LoRA (optionnel, défaut ci-dessous)
# AIDEAL_LORA_REMOTE_DIR=/opt/makesense-ai/lora-adapters/aideal-v1
